{
  "_comment": "Liste aller verfügbaren Apps + Standard-Images. Diese Datei sollte nicht manuell bearbeitet werden.",
  "_version": "1.0",
  "pihole": {
    "enabled": true,
    "profile": "minimal",
    "image": "pihole/pihole:latest",
    "ports": [
      "53:53/tcp",
      "53:53/udp",
      "8080:80/tcp"
    ],
    "environment": {
      "TZ": "Europe/Berlin"
    },
    "volumes": [
      "./data/pihole:/etc/pihole",
      "./data/dnsmasq:/etc/dnsmasq.d"
    ]
  },
  "portainer": {
    "enabled": true,
    "profile": "default",
    "image": "portainer/portainer-ce:latest",
    "ports": [
      "9000:9000"
    ],
    "volumes": [
      "/var/run/docker.sock:/var/run/docker.sock",
      "./data/portainer:/data"
    ]
  },
  "plex": {
    "enabled": false,
    "profile": "media",
    "image": "plexinc/pms-docker:plexpass",
    "ports": [
      "32400:32400/tcp"
    ],
    "environment": {
      "TZ": "Europe/Berlin",
      "PLEX_CLAIM": "claim-XXXXXXXXXXXXXXXXXXXXXXXX",
      "ADVERTISE_IP": "http://192.168.178.50:32400/"
    },
    "volumes": [
      "./data/plex/config:/config",
      "./media/movies:/movies",
      "./media/series:/series"
    ],
    "gpu_support": true
  }
}
