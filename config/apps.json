{
  "traefik": {
    "enabled": true,
    "image": "traefik:v3.1",
    "container_name": "traefik",
    "restart": "unless-stopped",
    "security_opt": ["no-new-privileges:true"],
    "networks": ["proxy"],
    "ports": [
      "${TRAEFIK_HTTP_PORT:-80}:80",
      "${TRAEFIK_HTTPS_PORT:-443}:443"
    ],
    "volumes": [
      "/var/run/docker.sock:/var/run/docker.sock:ro",
      "./traefik:/etc/traefik",
      "./data/traefik/acme.json:/acme.json"
    ],
    "environment": {
      "TZ": "${TIMEZONE:-Europe/Berlin}"
    },
    "labels": {
      "com.centurylinklabs.watchtower.enable": "true"
    }
  },
  "homepage": {
    "enabled": true,
    "image": "ghcr.io/gethomepage/homepage:latest",
    "container_name": "homepage",
    "restart": "unless-stopped",
    "networks": ["proxy"],
    "volumes": [
      "./config:/app/config",
      "./data/homepage:/app/data"
    ],
    "environment": {
      "TZ": "${TIMEZONE:-Europe/Berlin}",
      "HOMEPAGE_VAR_LOG_LEVEL": "${LOG_LEVEL:-info}"
    },
    "labels": {
      "traefik.enable": "true",
      "traefik.http.routers.homepage.rule": "PathPrefix(`/`)",
      "traefik.http.routers.homepage.entrypoints": "websecure",
      "traefik.http.routers.homepage.tls.certresolver": "letsencrypt",
      "com.centurylinklabs.watchtower.enable": "true"
    }
  },
  "portainer": {
    "enabled": true,
    "image": "portainer/portainer-ce:latest",
    "container_name": "portainer",
    "restart": "unless-stopped",
    "networks": ["proxy"],
    "volumes": [
      "/var/run/docker.sock:/var/run/docker.sock",
      "./data/portainer:/data"
    ],
    "environment": {
      "TZ": "${TIMEZONE:-Europe/Berlin}"
    },
    "labels": {
      "traefik.enable": "true",
      "traefik.http.routers.portainer.rule": "PathPrefix(`/portainer`)",
      "traefik.http.routers.portainer.entrypoints": "websecure",
      "traefik.http.routers.portainer.tls.certresolver": "letsencrypt",
      "com.centurylinklabs.watchtower.enable": "true"
    }
  },
  "watchtower": {
    "enabled": true,
    "image": "containrrr/watchtower:latest",
    "restart": "unless-stopped",
    "volumes": [
      "/var/run/docker.sock:/var/run/docker.sock"
    ],
    "environment": {
      "WATCHTOWER_CLEANUP": "true",
      "WATCHTOWER_POLL_INTERVAL": "3600",
      "TZ": "${TIMEZONE:-Europe/Berlin}"
    },
    "command": "--interval 3600"
  },

  "grass": {
    "enabled": false,
    "image": "ghcr.io/grass-mower/grass-node:latest",
    "restart": "unless-stopped",
    "environment": {
      "EMAIL": "",
      "PASSWORD": "",
      "USER_ID": "",
      "DEVICE_NAME": "raspberry-pi"
    },
    "volumes": [
      "./data/grass:/data"
    ]
  },

  "honeygain": {
    "enabled": false,
    "image": "honeygain/honeygain:latest",
    "restart": "unless-stopped",
    "environment": {
      "EMAIL": "",
      "PASSWORD": "",
      "DEVICE_NAME": "raspberry-pi"
    },
    "volumes": [
      "./data/honeygain:/data"
    ]
  },

  "earnapp": {
    "enabled": false,
    "image": "fazalfarooq/earnapp:latest",
    "restart": "unless-stopped",
    "environment": {
      "EARNAPP_TOKEN": ""
    },
    "volumes": [
      "./data/earnapp:/app/data"
    ]
  },

  "iproyal": {
    "enabled": false,
    "image": "iproyal/pawns-cli:latest",
    "restart": "unless-stopped",
    "environment": {
      "IPROYAL_EMAIL": "",
      "IPROYAL_PASSWORD": "",
      "IPROYAL_DEVICE_NAME": "raspberry-pi"
    }
  },

  "repocket": {
    "enabled": false,
    "image": "repocket/repocket:latest",
    "restart": "unless-stopped",
    "environment": {
      "REPOCKET_EMAIL": "",
      "REPOCKET_API_KEY": ""
    },
    "volumes": [
      "./data/repocket:/data"
    ]
  },

  "traffmonetizer": {
    "enabled": false,
    "image": "traffmonetizer/cli:latest",
    "restart": "unless-stopped",
    "command": "start accept --token ${TRAFFMONETIZER_TOKEN}"
  },

  "packetstream": {
    "enabled": false,
    "image": "packetstream/psclient:latest",
    "restart": "unless-stopped",
    "environment": {
      "CID": ""
    }
  },

  "myst": {
    "enabled": false,
    "image": "myst/myst:latest",
    "restart": "unless-stopped",
    "environment": {
      "MYST_WALLET": ""
    },
    "ports": [
      "4449:4449"
    ]
  }
}
