{
  "apps": {
    "earnapp": {
      "image": "farukt/docker-earnapp:latest",
      "restart": "unless-stopped",
      "environment": {
        "EARNAPP_UUID": "",
        "EARNAPP_EMAIL": "",
        "EARNAPP_REFCODE": ""
      },
      "volumes": [
        "./data/earnapp:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "honeygain": {
      "image": "honeygain/honeygain:latest",
      "restart": "unless-stopped",
      "environment": {
        "EMAIL": "",
        "PASS": ""
      },
      "volumes": [
        "./data/honeygain:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "iproyal": {
      "image": "iproyal/pawns-cli:latest",
      "restart": "unless-stopped",
      "environment": {
        "EMAIL": "",
        "PASSWORD": ""
      },
      "volumes": [
        "./data/iproyal:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "packetstream": {
      "image": "packetstream/psclient:latest",
      "restart": "unless-stopped",
      "environment": {
        "CID": ""
      },
      "volumes": [
        "./data/packetstream:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "peer2profit": {
      "image": "peer2profit/peer2profit_x86_64:latest",
      "restart": "unless-stopped",
      "environment": {
        "EMAIL": ""
      },
      "volumes": [
        "./data/peer2profit:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "traffmonetizer": {
      "image": "traffmonetizer/cli_v2:latest",
      "restart": "unless-stopped",
      "environment": {
        "TOKEN": ""
      },
      "volumes": [
        "./data/traffmonetizer:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "repocket": {
      "image": "repocket/repocket-node:latest",
      "restart": "unless-stopped",
      "environment": {
        "EMAIL": "",
        "API_KEY": ""
      },
      "volumes": [
        "./data/repocket:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "earnfish": {
      "image": "earnfish/earnfish:latest",
      "restart": "unless-stopped",
      "environment": {
        "TOKEN": ""
      },
      "volumes": [
        "./data/earnfish:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "bitping": {
      "image": "bitping/node:latest",
      "restart": "unless-stopped",
      "environment": {
        "EMAIL": "",
        "PASSWORD": "",
        "MFA_CODE": ""
      },
      "volumes": [
        "./data/bitping:/app/data"
      ],
      "network_mode": "host",
      "privileged": false
    },
    "mysterium": {
      "image": "mysteriumnetwork/myst:latest",
      "restart": "unless-stopped",
      "environment": {
        "IDENTITY_PASSWORD": ""
      },
      "volumes": [
        "./data/mysterium:/var/lib/mysterium-node"
      ],
      "network_mode": "host",
      "ports": [
        "4449:4449"
      ],
      "cap_add": ["NET_ADMIN"],
      "privileged": true,
      "devices": ["/dev/net/tun"]
    }
  }
}
