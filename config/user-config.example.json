{
  "_WARNING_": "=====================================================",
  "_WARNING_": "DIESE DATEI IST NUR EIN BEISPIEL!",
  "_WARNING_": "Kopiere diese Datei nach 'user-config.json' und passe die Werte an.",
  "_WARNING_": "Die Datei 'user-config.json' wird von .gitignore ignoriert und sollte NIE ins Git hochgeladen werden!",
  "_WARNING_": "=====================================================",
  
  "network": {
    "subnet": "192.168.178.0/24",
    "gateway": "192.168.178.1",
    "interface": "eth0",
    "dns": ["192.168.178.1", "1.1.1.1"]
  },
  
  "services": {
    "homepage": {
      "enabled": true,
      "port": 3000,
      "name": "Homepage"
    },
    "portainer": {
      "enabled": true,
      "port": 9000,
      "name": "Portainer"
    },
    "watchtower": {
      "enabled": true,
      "schedule": "0 4 * * *"
    },
    "fail2ban": {
      "enabled": true
    }
  },
  
  "storage": {
    "base_path": "/opt/passivestack",
    "data_path": "/opt/passivestack/data"
  },
  
  "security": {
    "timezone": "Europe/Berlin",
    "log_level": "info",
    "auto_update": true
  },
  
  "notes": [
    "Ändere alle Passwörter und Ports nach deinen Wünschen.",
    "Der Ordner 'data/' wird von .gitignore ignoriert.",
    "Nach dem Anpassen diese Datei in 'user-config.json' umbenennen."
  ]
}
