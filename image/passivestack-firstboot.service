[Unit]
Description=PassiveStack First Boot Setup
After=network-online.target
Wants=network-online.target
ConditionPathExists=/home/pi/passivestack/.firstboot_pending

[Service]
Type=oneshot
ExecStart=/bin/bash /home/pi/passivestack/image/firstboot.sh
RemainAfterExit=yes
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
