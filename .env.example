# =============================================
# PassiveStack – .env.example
# =============================================
# Diese Datei dient nur als Vorlage.
# Kopiere sie nach `.env` und passe die Werte an.
# Die echte `.env` Datei wird von .gitignore ignoriert!

# ------------------------------------------------
# Allgemeine Einstellungen
# ------------------------------------------------
COMPOSE_PROJECT_NAME=passivestack
TIMEZONE=Europe/Berlin
LOG_LEVEL=info

# ------------------------------------------------
# Netzwerk-Einstellungen (an dein Heimnetz anpassen!)
# ------------------------------------------------
SUBNET=192.168.178.0/24
GATEWAY=192.168.178.1
INTERFACE=eth0
DNS_SERVERS=192.168.178.1,1.1.1.1

# ------------------------------------------------
# Basis-Pfade
# ------------------------------------------------
BASE_PATH=/opt/passivestack
DATA_PATH=/opt/passivestack/data

# ------------------------------------------------
# Ports (bei Konflikten ändern)
# ------------------------------------------------
HOMEPAGE_PORT=3000
PORTAINER_PORT=9000
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# ------------------------------------------------
# Sicherheits- & Admin-Passwörter (unbedingt ändern!)
# ------------------------------------------------
# Verwende starke, eindeutige Passwörter
PORTAINER_ADMIN_PASSWORD=change_me_strong_password_123
WATCHTOWER_NOTIFICATION_EMAIL=your-email@example.com

# ------------------------------------------------
# Domain / DuckDNS / Reverse Proxy (optional)
# ------------------------------------------------
DOMAIN=your-domain.duckdns.org
DUCKDNS_TOKEN=your_duckdns_token_here
EMAIL=your-email@example.com

# =============================================
# WICHTIGER HINWEIS:
# 1. Kopiere diese Datei: cp .env.example .env
# 2. Öffne .env und passe ALLE Werte an
# 3. Verwende niemals echte Passwörter in dieser .example Datei
# =============================================
