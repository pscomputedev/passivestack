# =============================================
# PassiveStack – SICHERE .gitignore
# =============================================

# === GEHEIME / SENSIBLE DATEIEN (NIE ins Git hochladen!) ===
.env
.env.local
.env.*.local
user-config.json
config/user-config.json
secrets.json

# === GENERIERTE / AUTOMATISCH ERSTELLTE DATEIEN ===
docker-compose.yaml
docker-compose.yml
compose.yaml
generated/
config/user-config.example.json

# === DATENVERZEICHNISSE (können groß werden oder sensible Daten enthalten) ===
data/
media/
.downloads/
downloads/
.data/

# === LOGS ===
*.log
logs/
*.log.*

# === TEMPORÄRE DATEIEN ===
tmp/
temp/
*.tmp
*.temp

# === PYTHON CACHE & BUILD ARTEFAKTE ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
wheels/
pip-wheel-metadata/

# === IDEs & Editoren ===
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# === OS GENERIERTE DATEIEN ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === DOCKER ===
.dockerignore
docker-compose.override.yml

# === SONSTIGES ===
node_modules/
coverage/
.coverage
*.bak
*.backup
